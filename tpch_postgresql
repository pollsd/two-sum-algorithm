/* =========================================================
   QUESTION 1
   Run Q17, capture runtime and query plan
   ========================================================= */

/* Q1 Original Q17 */
/* Runtime: <put your measured execution time here in ms> */

EXPLAIN ANALYZE
SELECT
    SUM(l_extendedprice) / 7.0 AS avg_yearly
FROM
    lineitem,
    part
WHERE
    p_partkey = l_partkey
    AND p_brand = 'Brand#23'
    AND p_container = 'MED BOX'
    AND l_quantity < (
        SELECT
            0.2 * AVG(l_quantity)
        FROM
            lineitem
        WHERE
            l_partkey = p_partkey
    );


/* =========================================================
   QUESTION 1 / 2 SUPPORT
   Unnested version of Q17
   ========================================================= */

DROP TABLE IF EXISTS temp;

CREATE TEMP TABLE temp AS
SELECT
    l_partkey,
    0.2 * AVG(l_quantity) AS threshold
FROM
    lineitem
GROUP BY
    l_partkey;

/* Optional: measure rewritten Q17 */
/* Runtime: <put your measured execution time here in ms> */

EXPLAIN ANALYZE
SELECT
    SUM(l_extendedprice) / 7.0 AS avg_yearly
FROM
    part,
    temp,
    lineitem
WHERE
    p_partkey = temp.l_partkey
    AND p_partkey = lineitem.l_partkey
    AND p_brand = 'Brand#23'
    AND p_container = 'MED BOX'
    AND lineitem.l_quantity < temp.threshold;


/* =========================================================
   QUESTION 2
   Materialized view for two TPCH queries: Q4 and Q18
   ========================================================= */

DROP MATERIALIZED VIEW IF EXISTS mv_q4_q18;

CREATE MATERIALIZED VIEW mv_q4_q18 AS
SELECT
    o.o_orderkey,
    o.o_orderpriority,
    o.o_orderdate,
    SUM(l.l_quantity) AS sum_qty,
    SUM(
        CASE
            WHEN l.l_commitdate < l.l_receiptdate THEN 1
            ELSE 0
        END
    ) AS late_line_count
FROM
    orders o
    JOIN lineitem l
        ON l.l_orderkey = o.o_orderkey
GROUP BY
    o.o_orderkey,
    o.o_orderpriority,
    o.o_orderdate;


/* Rewritten Q4 */
/* Validation value: DATE = 1993-07-01 */

SELECT
    o_orderpriority,
    COUNT(*) AS order_count
FROM
    mv_q4_q18
WHERE
    o_orderdate >= DATE '1993-07-01'
    AND o_orderdate < DATE '1993-07-01' + INTERVAL '3 month'
    AND late_line_count > 0
GROUP BY
    o_orderpriority
ORDER BY
    o_orderpriority;


/* Rewritten Q18 */
/* Validation value: QUANTITY = 300 */

SELECT
    c.c_name,
    c.c_custkey,
    o.o_orderkey,
    o.o_orderdate,
    o.o_totalprice,
    mv.sum_qty
FROM
    customer c,
    mv_q4_q18 mv,
    orders o
WHERE
    c.c_custkey = o.o_custkey
    AND o.o_orderkey = mv.o_orderkey
    AND mv.sum_qty > 300
ORDER BY
    o.o_totalprice DESC,
    o.o_orderdate
FETCH FIRST 100 ROWS ONLY;


