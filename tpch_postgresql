/* =========================================================
   COLUMN STORE SIMULATION
   Create narrow table for Q6
   ========================================================= */

DROP TABLE IF EXISTS lineitem_q6;

CREATE TABLE lineitem_q6 AS
SELECT
    l_shipdate,
    l_discount,
    l_quantity,
    l_extendedprice
FROM
    lineitem;


/* =========================================================
   COLUMN STORE SIMULATION
   Run Q6 on narrow table and capture runtime
   Validation values:
   DATE = 1994-01-01
   DISCOUNT = 0.06
   QUANTITY = 24
   ========================================================= */

/* Runtime on lineitem_q6: <put your measured execution time here in ms> */

EXPLAIN ANALYZE
SELECT
    SUM(l_extendedprice * l_discount) AS revenue
FROM
    lineitem_q6
WHERE
    l_shipdate >= DATE '1994-01-01'
    AND l_shipdate < DATE '1994-01-01' + INTERVAL '1 year'
    AND l_discount BETWEEN 0.06 - 0.01 AND 0.06 + 0.01
    AND l_quantity < 24;


